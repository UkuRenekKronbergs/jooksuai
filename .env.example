# Copy to .env and fill in. .env is gitignored.

# --- LLM pakkuja — vali üks: anthropic | openai | openrouter | google ---

# Anthropic Claude (otse)
ANTHROPIC_API_KEY=

# OpenAI (otse)
OPENAI_API_KEY=

# OpenRouter (üks võti, ligipääs mitmele mudelile — Claude, GPT, Llama jne)
# Loo võti: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google AI Studio (Gemini, suur tasuta-kvoot: 15 RPM / 1500 RPD Flash-Lite-il)
# Loo võti: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# --- Strava OAuth (valikuline, rakendus töötab ka ilma) ---
# Loo app: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# --- Supabase (valikuline — lülitab sisse multi-user režiimi + sisselogimise) ---
# Loo projekt: https://supabase.com/dashboard
# Dashboard → Settings → API → Project URL ja `anon` `public` võti.
# Anon-võti on disainilt avalik (kaitstud Row-Level Security'ga); ära kunagi
# kasuta siin `service_role` võtit.
# Kui mõlemad puudu, käivitub rakendus lokaalse SQLite + ilma login'ita.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Mudelivalikud ---
# LLM_PROVIDER väärtused:
#   openrouter  → OPENROUTER_API_KEY, LLM_MODEL nt:
#     - `deepseek/deepseek-v4-flash:free`           ← tasuta, 1M context (soovitan)
#     - `openai/gpt-oss-120b:free`                  ← tasuta, 120B
#     - `nousresearch/hermes-3-llama-3.1-405b:free` ← tasuta, 405B
#     - `meta-llama/llama-3.3-70b-instruct:free`   ← tasuta, kiire (mõnikord rate-limited)
#     - `anthropic/claude-sonnet-4.6`              ← tasuline, kõrgeim kvaliteet
#   google      → GOOGLE_API_KEY (https://aistudio.google.com/app/apikey), LLM_MODEL nt:
#     - `gemini-3.1-flash-lite`   ← tasuta, suur kvoot (15 RPM / 1500 RPD), hea JSON
#     - `gemini-2.5-flash`        ← tasuta, suurem kontekst
#     - `gemini-2.5-pro`          ← tasuta tagasihoidlikult, parim kvaliteet
#   anthropic   → ANTHROPIC_API_KEY, LLM_MODEL nt `claude-sonnet-4-6`
#   openai      → OPENAI_API_KEY, LLM_MODEL nt `gpt-4o-2024-08-06`
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-v4-flash:free
LLM_TEMPERATURE=0
