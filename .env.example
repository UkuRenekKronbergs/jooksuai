# Copy to .env and fill in. .env is gitignored.

# Anthropic Claude (soovituslik LLM pakkuja)
ANTHROPIC_API_KEY=

# OpenAI (varuvariant, valikuline)
OPENAI_API_KEY=

# Strava OAuth (valikuline, rakendus töötab ka ilma)
# Loo app: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Mudelivalikud
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0
